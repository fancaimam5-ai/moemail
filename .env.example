# ===================================================================
# Authentication (NextAuth.js / next-auth v5)
# ===================================================================

# OAuth providers — create apps at:
#   GitHub: https://github.com/settings/developers
#   Google: https://console.cloud.google.com/apis/credentials
AUTH_GITHUB_ID = ""
AUTH_GITHUB_SECRET = ""
AUTH_GOOGLE_ID = ""
AUTH_GOOGLE_SECRET = ""

# Random secret for signing tokens — generate with:
#   openssl rand -base64 32
AUTH_SECRET = ""

# Your deployed app URL — required for NextAuth callbacks
# Also accepted as NEXTAUTH_URL for v4 compatibility
AUTH_URL = ""

# ===================================================================
# Cloudflare Deployment
# ===================================================================

# Get these from https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_API_TOKEN = ""
CLOUDFLARE_ACCOUNT_ID = ""

# Names for Cloudflare resources (created automatically by deploy script)
DATABASE_NAME = "moemail-db"
KV_NAMESPACE_NAME = "moemail-kv"

# Cloudflare project name (used by deploy and wrangler scripts)
PROJECT_NAME = "moemail"

# Resource IDs — leave empty to auto-detect from resource names above
# After first deploy these are populated automatically into wrangler.json
DATABASE_ID = ""
KV_NAMESPACE_ID = ""

# Your deployed app URL (e.g. https://your-app.pages.dev or custom domain)
CUSTOM_DOMAIN = ""

# ===================================================================
# Cloudflare Worker — Cron / Cleanup
# ===================================================================

# URL of your deployed Next.js app — used by the cleanup worker to trigger notifications
# Example: https://your-app.pages.dev
WORKER_ORIGIN = ""

# Secret shared between the cleanup worker and the Next.js app cron endpoint
# Generate with: openssl rand -hex 32
CRON_SECRET = ""

# ===================================================================
# Runtime Configuration (set via Admin UI after deployment)
# ===================================================================
# The following are configured through the Admin panel, NOT via .env:
#
#   - Email provider (Resend API Key, SendGrid, custom SMTP relay)
#   - DOKU payment gateway credentials (Merchant ID + Secret Key)
#   - Cloudflare Turnstile CAPTCHA (Site Key + Secret Key)
#   - Default user role for new registrations
#   - Allowed email domains
#   - Per-role daily send limits
#   - Admin contact email
#
# Access the Admin panel at: https://<your-domain>/<locale>/admin
#
# NOTE: Never commit your actual .env file — it is listed in .gitignore
# ===================================================================
